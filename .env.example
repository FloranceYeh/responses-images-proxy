# Copy this file to .env or export these variables before running docker compose.
HOST=0.0.0.0
PORT=8000
UPSTREAM_BASE_URL=https://your-upstream.example.com
UPSTREAM_API_KEY=sk-upstream
PROXY_API_KEY=local-secret
DEFAULT_MODEL=gpt-5.3-codex
UPSTREAM_IMAGE_OUTPUT_FORMAT=png
IMAGE_RACE_CONCURRENCY=1
MAX_IMAGE_RACE_CONCURRENCY=4
MAX_TOTAL_UPSTREAM_CALLS=8
MAX_IMAGE_UPSTREAM_CONCURRENCY=4
MAX_OUTPUT_IMAGES=4
UPSTREAM_TIMEOUT_MS=180000
MAX_ERROR_BODY_BYTES=8192
MAX_REQUEST_BYTES=83886080
MAX_INPUT_IMAGE_BYTES=26214400
MAX_INPUT_IMAGES=8
ALLOW_REMOTE_IMAGE_URLS=false
CORS_ALLOW_ORIGIN=*
LOG_LEVEL=info
LOG_SSE_DATA=false
IMAGE_PARTIAL_FALLBACK=false
LOG_PRETTY=true
